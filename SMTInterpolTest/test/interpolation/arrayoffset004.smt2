(set-option :produce-interpolants true)
(set-option :interpolant-check-mode true)
(set-logic QF_ALIA)
(set-info :status unsat)
(declare-const a (Array Int Int))
(declare-const b (Array Int Int))
(declare-const c (Array Int Int))
(declare-const i Int)
(declare-const j Int)
(declare-const v Int)
(declare-const w Int)
;; weakeq-ext: both stores hit the same cell (i+1 = j+2) with the same value
(assert (! (and (= a (store c (+ i 1) v)) (= i (+ j 1))) :named A))
(assert (! (and (= b (store c (+ j 2) w)) (= v w) (not (= a b))) :named B))
(check-sat)
(get-interpolants A B)
(get-interpolants B A)
(exit)
