(set-option :produce-proofs true)
(set-option :produce-models true)
(set-logic QF_BV)

(declare-const a (_ BitVec 32))
(declare-const b (_ BitVec 32))
(declare-const c (_ BitVec 32))

(assert (bvuaddo a b))
(assert (not (bvuaddo a c)))
(assert (not (bvuaddo (_ bv0 4) (_ bv0 4))))
(assert (not (bvuaddo (_ bv1 4) (_ bv0 4))))
(assert (not (bvuaddo (_ bv1 4) (_ bv1 4))))
(assert (not (bvuaddo (_ bv3 4) (_ bv9 4))))
(assert (not (bvuaddo (_ bv0 4) (_ bv15 4))))
(assert (not (bvuaddo (_ bv14 4) (_ bv1 4))))
(assert (bvuaddo (_ bv14 4) (_ bv2 4)))
(assert (bvuaddo (_ bv13 4) (_ bv3 4)))
(assert (bvuaddo (_ bv14 4) (_ bv8 4)))
(assert (bvuaddo (_ bv15 4) (_ bv15 4)))
(check-sat)
