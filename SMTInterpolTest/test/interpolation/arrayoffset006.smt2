(set-option :produce-interpolants true)
(set-option :interpolant-check-mode true)
(set-logic QF_ALIA)
(set-info :status unsat)
(declare-const a (Array Int Int))
(declare-const b (Array Int Int))
(declare-const i Int)
(declare-const j Int)
(declare-const k Int)
(declare-const v Int)
;; index equality derived via LA: i = k+1 (A), j = k+2 (B), so j = i+1 = store index
(assert (! (and (= b (store a (+ i 1) v)) (<= i (+ k 1)) (>= i (+ k 1))) :named A))
(assert (! (and (<= j (+ k 2)) (>= j (+ k 2)) (not (= (select b j) v))) :named B))
(check-sat)
(get-interpolants A B)
(get-interpolants B A)
(exit)
