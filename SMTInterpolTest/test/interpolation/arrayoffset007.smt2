(set-option :produce-interpolants true)
(set-option :interpolant-check-mode true)
(set-logic QF_ALIA)
(set-info :status unsat)
(declare-const a (Array Int Int))
(declare-const b (Array Int Int))
(declare-const i Int)
(declare-const j Int)
(declare-const k Int)
(declare-const v Int)
;; read-over-weakeq between two selects with shifted indices i+1 = j+2
(assert (! (and (= b (store a (+ k 1) v)) (not (= k i))) :named A))
(assert (! (and (= i (+ j 1)) (not (= (select b (+ i 1)) (select a (+ j 2))))) :named B))
(check-sat)
(get-interpolants A B)
(get-interpolants B A)
(exit)
