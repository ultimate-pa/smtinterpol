(set-option :produce-interpolants true)
(set-option :interpolant-check-mode true)
(set-logic QF_ALIA)
(set-info :status unsat)
(declare-const a (Array Int Int))
(declare-const b (Array Int Int))
(declare-const i Int)
(declare-const j Int)
(declare-const v Int)
;; weakeq-ext: store position patched by a select equality at shifted index j+2 = i+1
(assert (! (= a (store b (+ i 1) v)) :named A))
(assert (! (and (= i (+ j 1)) (= (select a (+ j 2)) (select b (+ j 2))) (not (= a b))) :named B))
(check-sat)
(get-interpolants A B)
(get-interpolants B A)
(exit)
