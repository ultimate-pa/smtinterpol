(set-option :produce-interpolants true)
(set-option :interpolant-check-mode true)
(set-logic QF_ALIA)
(set-info :status unsat)
(declare-const a (Array Int Int))
(declare-const b (Array Int Int))
(declare-const i Int)
(declare-const k Int)
(declare-const v Int)
;; read-over-store through equality k = i+1, stored value carries an offset v+1
(assert (! (= b (store a (+ i 1) (+ v 1))) :named A))
(assert (! (and (= k (+ i 1)) (not (= (select b k) (+ v 1)))) :named B))
(check-sat)
(get-interpolants A B)
(get-interpolants B A)
(exit)
