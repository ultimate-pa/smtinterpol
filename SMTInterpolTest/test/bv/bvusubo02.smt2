(set-option :produce-proofs true)
(set-option :produce-models true)
(set-logic QF_BV)

(declare-const a (_ BitVec 32))
(declare-const b (_ BitVec 32))
(declare-const c (_ BitVec 32))

(assert (bvusubo a b))
(assert (not (bvusubo a c)))
(assert (not (bvusubo (_ bv0 4) (_ bv0 4))))
(assert (not (bvusubo (_ bv1 4) (_ bv0 4))))
(assert (not (bvusubo (_ bv1 4) (_ bv1 4))))
(assert (not (bvusubo (_ bv9 4) (_ bv3 4))))
(assert (not (bvusubo (_ bv15 4) (_ bv15 4))))
(assert (not (bvusubo (_ bv14 4) (_ bv1 4))))
(assert (bvusubo (_ bv14 4) (_ bv15 4)))
(assert (bvusubo (_ bv8 4) (_ bv9 4)))
(assert (bvusubo (_ bv0 4) (_ bv15 4)))
(assert (bvusubo (_ bv2 4) (_ bv5 4)))
(check-sat)
