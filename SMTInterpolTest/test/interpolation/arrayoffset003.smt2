(set-option :produce-interpolants true)
(set-option :interpolant-check-mode true)
(set-logic QF_ALIA)
(set-info :status unsat)
(declare-const a (Array Int Int))
(declare-const x Int)
(declare-const y Int)
(declare-const k Int)
;; read-const-weakeq: const array with offset value, read shifted through y = x+2
(assert (! (= a ((as const (Array Int Int)) (+ x 1))) :named A))
(assert (! (and (= y (+ x 2)) (not (= (select a k) (+ y (- 1))))) :named B))
(check-sat)
(get-interpolants A B)
(get-interpolants B A)
(exit)
