(set-logic ALL)
(set-info :status unsat)
(declare-const a (Array (_ BitVec 1) Real))
(declare-const a1 (Array (_ BitVec 1) Real))
(declare-const b (Array (_ BitVec 1) Real))
(declare-const b1 (Array (_ BitVec 1) Real))
(assert (= (store (store a (_ bv1 1) 0.0) (_ bv0 1) 1.0) a1))
(assert (= (store (store b (_ bv1 1) 0.0) (_ bv0 1) 1.0) b1))
(assert (not (= a1 b1)))
(check-sat)
