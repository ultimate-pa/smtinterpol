(set-option :produce-proofs true)
(set-option :produce-models true)
(set-logic QF_BV)

(declare-const a (_ BitVec 32))
(declare-const b (_ BitVec 32))
(declare-const c (_ BitVec 32))

(assert (bvssubo a b))
(assert (not (bvssubo a c)))
(assert (not (bvssubo (_ bv0 4) (_ bv15 4))))
(assert (not (bvssubo (_ bv1 4) (_ bv0 4))))
(assert (not (bvssubo (_ bv1 4) (_ bv15 4))))
(assert (not (bvssubo (_ bv3 4) (_ bv12 4))))
(assert (not (bvssubo (_ bv15 4) (_ bv1 4))))
(assert (not (bvssubo (_ bv12 4) (_ bv4 4))))
(assert (bvssubo (_ bv7 4) (_ bv15 4)))
(assert (bvssubo (_ bv8 4) (_ bv1 4)))
(assert (bvssubo (_ bv10 4) (_ bv3 4)))
(assert (bvssubo (_ bv5 4) (_ bv13 4)))
(check-sat)
