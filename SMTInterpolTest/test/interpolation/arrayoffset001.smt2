(set-option :produce-interpolants true)
(set-option :interpolant-check-mode true)
(set-logic QF_ALIA)
(set-info :status unsat)
(declare-const a (Array Int Int))
(declare-const b (Array Int Int))
(declare-const i Int)
(declare-const j Int)
(declare-const v Int)
;; read-over-weakeq with shifted indices: store at i+1, read at j+2, i+1 != j+2
(assert (! (= b (store a (+ i 1) v)) :named A))
(assert (! (and (not (= (select b (+ j 2)) (select a (+ j 2)))) (not (= i (+ j 1)))) :named B))
(check-sat)
(get-interpolants A B)
(get-interpolants B A)
(exit)
